# Copy this to a private local env file or systemd Environment= lines.
# Do not commit your real password hash/session secret.
MISSION_HOST=127.0.0.1
MISSION_PORT=8787
MISSION_USER=Clint
MISSION_PASSWORD_HASH=scrypt:PASTE_HASH_HERE
MISSION_SESSION_SECRET=PASTE_RANDOM_HEX_HERE
MISSION_OPENCLAW_BIN=/home/clint-craig/.npm-global/bin/openclaw
MISSION_ACPX_BIN=/home/clint-craig/.openclaw/npm/node_modules/.bin/acpx
MISSION_GROK_BIN=/home/clint-craig/.local/bin/grok
MISSION_AGENTBUS_SEND_BIN=/home/clint-craig/shared-workspace/agentbus/agentbus-send.py
MISSION_AGENTBUS_ENV_FILE=/etc/agentbus/Buddy.env
MISSION_AGENTBUS_REPLY_WAIT_MS=90000
