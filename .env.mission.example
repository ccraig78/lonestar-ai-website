# Leave off for safe prototype replies. Turn on only when you want button clicks to spend model tokens.
MISSION_OPENCLAW_ENABLED=0
MISSION_AGENT_BUDDY=main
MISSION_AGENT_STELLA=lonestar
MISSION_CODI_ROUTE_TYPE=acpx
MISSION_CODI_ACPX_AGENT=codi
